DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
NEON_AUTH_BASE_URL="https://your-production-domain.com"
NEON_AUTH_COOKIE_SECRET="replace-with-a-long-random-secret"
# Optional. Set only when Neon Auth cookies are intentionally shared across subdomains.
NEON_AUTH_COOKIE_DOMAIN=""

# Optional seed-only values. Do not run seed against production unless intended.
SEED_SUPER_ADMIN_EMAILS=""
SEED_BRANCH_ADMIN_EMAILS=""
SEED_CASHIER_EMAILS=""
SEED_BRANCH_CODE="MAIN"
SEED_BRANCH_NAME="Main Branch"
