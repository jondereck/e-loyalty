generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id               String             @id @default(cuid())
  authUserId       String             @unique
  fullName         String
  username         String?            @unique
  mobile           String?            @unique
  email            String             @unique
  status           UserStatus         @default(ACTIVE)
  mustChangePassword Boolean          @default(false)
  roles            AppRole[]          @default([CUSTOMER])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  auditEvents      AuditEvent[]       @relation("ActorAuditEvents")
  notifications    Notification[]
  loyaltyCard      LoyaltyCard?
  ledgerEntries    PointLedger[]
  redemptions      RewardRedemption[]
  staffAssignments StaffAssignment[]
  cashierVisits    Visit[]            @relation("CashierVisits")
  visits           Visit[]            @relation("CustomerVisits")
}

model LoyaltyCard {
  id            String             @id @default(cuid())
  profileId     String             @unique
  cardNumber    String             @unique
  qrToken       String             @unique
  status        LoyaltyCardStatus  @default(ACTIVE)
  tier          String             @default("Starter")
  visitsEarned  Int                @default(0)
  pointsBalance Int                @default(0)
  totalEarned   Int                @default(0)
  totalRedeemed Int                @default(0)
  lastVisitAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  profile       UserProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ledgerEntries PointLedger[]
  redemptions   RewardRedemption[]
  scanAttempts  ScanAttempt[]
  visits        Visit[]
}

model Branch {
  id               String             @id @default(cuid())
  code             String             @unique
  name             String
  status           BranchStatus       @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  address          String?
  phone            String?
  email            String?
  latitude         Float?
  longitude        Float?
  redemptions      RewardRedemption[]
  scanAttempts     ScanAttempt[]
  staffAssignments StaffAssignment[]
  visits           Visit[]
}

model StaffAssignment {
  id        String                @id @default(cuid())
  profileId String
  branchId  String
  role      AppRole
  roleId    String?
  status    StaffAssignmentStatus @default(ACTIVE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  branch    Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  profile   UserProfile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  roleDefinition AccessRole?       @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([profileId, branchId, role])
  @@index([roleId])
}

model AccessRole {
  id              String           @id @default(cuid())
  key             String           @unique
  name            String
  normalizedName  String           @unique
  description     String
  status          RoleStatus       @default(ACTIVE)
  baseRole        AppRole
  systemRole      AppRole?
  defaultModule   RoleModuleKey
  protected       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  permissions     RolePermission[]
  staffAssignments StaffAssignment[]
}

model RolePermission {
  id        String        @id @default(cuid())
  roleId    String
  module    RoleModuleKey
  createdAt DateTime      @default(now())
  role      AccessRole     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@index([module])
}

model Visit {
  id             String           @id @default(cuid())
  loyaltyCardId  String
  customerId     String
  branchId       String
  cashierId      String
  status         VisitStatus      @default(PENDING)
  approvalStatus ApprovalStatus   @default(REQUIRED)
  reasonCode     VisitReasonCode?
  reason         String?
  pointsAwarded  Int              @default(0)
  scannedAt      DateTime         @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  reviewedById   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  businessDate   String           @default("")
  earnKey        String?          @unique
  adminNote      String?
  auditEvents    AuditEvent[]
  ledgerEntries  PointLedger[]
  branch         Branch           @relation(fields: [branchId], references: [id])
  cashier        UserProfile      @relation("CashierVisits", fields: [cashierId], references: [id])
  customer       UserProfile      @relation("CustomerVisits", fields: [customerId], references: [id], onDelete: Cascade)
  loyaltyCard    LoyaltyCard      @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
}

model PointLedger {
  id            String            @id @default(cuid())
  loyaltyCardId String
  profileId     String
  visitId       String?
  redemptionId  String?
  type          LedgerType
  points        Int
  description   String
  createdAt     DateTime          @default(now())
  loyaltyCard   LoyaltyCard       @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
  profile       UserProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  redemption    RewardRedemption? @relation(fields: [redemptionId], references: [id])
  visit         Visit?            @relation(fields: [visitId], references: [id])

  @@unique([visitId, type])
  @@unique([redemptionId, type])
}

model RewardMilestone {
  id             String             @id @default(cuid())
  name           String             @unique
  description    String
  pointsRequired Int
  pointsCost     Int                @default(0)
  status         RedemptionStatus   @default(AVAILABLE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  redemptions    RewardRedemption[]
}

model RewardRedemption {
  id            String           @id @default(cuid())
  milestoneId   String
  profileId     String
  loyaltyCardId String
  branchId      String?
  cashierId     String?
  status        RedemptionStatus @default(REDEEMED)
  createdAt     DateTime         @default(now())
  ledgerEntries PointLedger[]
  branch        Branch?          @relation(fields: [branchId], references: [id])
  loyaltyCard   LoyaltyCard      @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
  milestone     RewardMilestone  @relation(fields: [milestoneId], references: [id])
  profile       UserProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([loyaltyCardId, milestoneId])
}

model ScanAttempt {
  id                     String           @id @default(cuid())
  qrTokenHash            String?
  loyaltyCardId          String?
  branchId               String?
  cashierId              String?
  status                 VisitStatus?
  reasonCode             VisitReasonCode?
  message                String
  nextEligibleAt         DateTime?
  createdAt              DateTime         @default(now())
  businessDate           String?
  repeatedCustomerScan   Boolean          @default(false)
  repeatedCashierFailure Boolean          @default(false)
  invalidQrBurst         Boolean          @default(false)
  multipleBranchSameDay  Boolean          @default(false)
  branch                 Branch?          @relation(fields: [branchId], references: [id])
  loyaltyCard            LoyaltyCard?     @relation(fields: [loyaltyCardId], references: [id])
}

model AuditEvent {
  id        String       @id @default(cuid())
  actorId   String?
  visitId   String?
  action    String
  metadata  Json?
  createdAt DateTime     @default(now())
  actor     UserProfile? @relation("ActorAuditEvents", fields: [actorId], references: [id])
  visit     Visit?       @relation(fields: [visitId], references: [id])
}

model SystemSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum AppRole {
  CUSTOMER
  CASHIER
  BRANCH_ADMIN
  SUPER_ADMIN
}

enum LoyaltyCardStatus {
  ACTIVE
  BLOCKED
}

enum VisitStatus {
  PENDING
  AUTO_APPROVED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  NOT_REQUIRED
  REQUIRED
  APPROVED
  REJECTED
  OVERRIDDEN
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum StaffAssignmentStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
}

enum RoleModuleKey {
  OVERVIEW
  MEMBERS
  APPROVALS
  STAFF
  BRANCHES
  REPORTS
  SYSTEM_REPORTS
  SETTINGS
  SCAN
  ROLES_PERMISSIONS
}

enum LedgerType {
  EARN
  REDEEM
  ADJUST
}

enum RedemptionStatus {
  LOCKED
  AVAILABLE
  REDEEMED
  EXPIRED
  DISABLED
}

enum VisitReasonCode {
  DUPLICATE_SAME_DAY
  ALREADY_USED_OTHER_BRANCH
  INVALID_QR
  QR_NOT_FOUND
  CARD_BLOCKED
  CARD_INACTIVE
  CUSTOMER_INACTIVE
  BRANCH_INACTIVE
  UNAUTHORIZED_CASHIER
  SUSPICIOUS_ACTIVITY
  MANUAL_REVIEW_REQUIRED
  RECEIPT_CONFLICT
  SYSTEM_ERROR
}
